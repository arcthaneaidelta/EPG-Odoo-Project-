<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         Finance Transaction Views
         ================================================================ -->

    <!-- TREE VIEW -->
    <record id="view_finance_transaction_list" model="ir.ui.view">
        <field name="name">finance.transaction.list</field>
        <field name="model">finance.transaction</field>
        <field name="arch" type="xml">
            <list string="Transactions"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'"
                  default_order="date desc, id desc">
                <field name="name"/>
                <field name="date"/>
                <field name="account_id"/>
                <field name="type" widget="badge"
                       decoration-success="type == 'in'"
                       decoration-danger="type == 'out'"/>
                <field name="category_id" optional="show"/>
                <field name="partner_id" optional="show"/>
                <field name="amount" widget="monetary" sum="Total"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_finance_transaction_form" model="ir.ui.view">
        <field name="name">finance.transaction.form</field>
        <field name="model">finance.transaction</field>
        <field name="arch" type="xml">
            <form string="Finance Transaction">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state not in ('draft', 'confirmed')"
                            confirm="Are you sure you want to cancel this transaction?"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                            invisible="state != 'cancelled'"
                            groups="finance_treasury.group_treasury_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_journal_entry" type="object"
                                class="oe_stat_button" icon="fa-book"
                                invisible="not move_id"
                                string="Journal Entry"/>
                        <button name="action_open_transfer" type="object"
                                class="oe_stat_button" icon="fa-exchange"
                                invisible="not transfer_id"
                                string="Transfer"/>
                        <button name="action_open_exchange" type="object"
                                class="oe_stat_button" icon="fa-refresh"
                                invisible="not exchange_id"
                                string="Exchange"/>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="True"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Transaction Details">
                            <field name="date"/>
                            <field name="account_id"
                                   readonly="state != 'draft'"/>
                            <field name="type" widget="radio"
                                   readonly="state != 'draft'"/>
                            <field name="amount"
                                   readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="True"/>
                        </group>
                        <group string="Classification">
                            <field name="category_id"
                                   domain="[('type', '=', 'income' if type == 'in' else 'expense')]"
                                   readonly="state != 'draft'"/>
                            <field name="partner_id"
                                   readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"
                                   placeholder="Add details about this transaction..."
                                   readonly="state != 'draft'"/>
                        </page>
                        <page string="Technical" name="technical"
                              groups="base.group_no_one">
                            <group>
                                <field name="move_id"/>
                                <field name="transfer_id"/>
                                <field name="exchange_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_finance_transaction_search" model="ir.ui.view">
        <field name="name">finance.transaction.search</field>
        <field name="model">finance.transaction</field>
        <field name="arch" type="xml">
            <search string="Search Transactions">
                <field name="name"/>
                <field name="account_id"/>
                <field name="partner_id"/>
                <field name="category_id"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_month" string="This Month"
                        domain="[
                            ('date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                            ('date', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d')),
                        ]"/>
                <filter name="filter_this_year" string="This Year"
                        domain="[
                            ('date', '&gt;=', (context_today() - relativedelta(month=1, day=1)).strftime('%Y-%m-%d')),
                            ('date', '&lt;=', (context_today() + relativedelta(month=12, day=31)).strftime('%Y-%m-%d')),
                        ]"/>
                <separator/>
                <filter name="filter_income" string="Income" domain="[('type', '=', 'in')]"/>
                <filter name="filter_expense" string="Expense" domain="[('type', '=', 'out')]"/>
                <separator/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <group>
                    <filter name="group_account" string="Account" context="{'group_by': 'account_id'}"/>
                    <filter name="group_type" string="Type" context="{'group_by': 'type'}"/>
                    <filter name="group_category" string="Category" context="{'group_by': 'category_id'}"/>
                    <filter name="group_partner" string="Partner" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_finance_transaction" model="ir.actions.act_window">
        <field name="name">Transactions</field>
        <field name="res_model">finance.transaction</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_finance_transaction_search"/>
        <field name="context">{'search_default_filter_confirmed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first transaction
            </p>
            <p>
                Record all income and expense movements across your accounts.
            </p>
        </field>
    </record>

</odoo>
