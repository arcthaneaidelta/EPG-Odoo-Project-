<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         Sequence Definitions
         ================================================================ -->

    <!-- Finance Account Sequence -->
    <record id="seq_finance_account" model="ir.sequence">
        <field name="name">Finance Account</field>
        <field name="code">finance.account</field>
        <field name="prefix">ACC/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Finance Transaction Sequence -->
    <record id="seq_finance_transaction" model="ir.sequence">
        <field name="name">Finance Transaction</field>
        <field name="code">finance.transaction</field>
        <field name="prefix">TXN/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Finance Transfer Sequence -->
    <record id="seq_finance_transfer" model="ir.sequence">
        <field name="name">Finance Transfer</field>
        <field name="code">finance.transfer</field>
        <field name="prefix">TRF/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Finance Exchange Sequence -->
    <record id="seq_finance_exchange" model="ir.sequence">
        <field name="name">Finance Exchange</field>
        <field name="code">finance.exchange</field>
        <field name="prefix">EXC/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>


</odoo>
