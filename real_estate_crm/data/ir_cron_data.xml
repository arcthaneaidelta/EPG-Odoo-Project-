<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron job for recurring rental invoices -->
    <record id="ir_cron_create_recurring_invoices" model="ir.cron">
        <field name="name">Real Estate: Generate Recurring Rental Invoices</field>
        <field name="model_id" ref="model_real_estate_rental_contract"/>
        <field name="state">code</field>
        <field name="code">model.cron_create_recurring_invoices()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_auto_currency_update" model="ir.cron">
        <field name="name">Real Estate: Auto Update Currencies</field>
        <field name="model_id" ref="model_real_estate_currency_updater"/>
        <field name="state">code</field>
        <field name="code">model.run_currency_update()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>
