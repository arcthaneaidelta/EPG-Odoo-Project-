<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Property Tree View -->
    <record id="view_real_estate_property_tree" model="ir.ui.view">
        <field name="name">real.estate.property.tree</field>
        <field name="model">real.estate.property</field>
        <field name="arch" type="xml">
            <list string="Properties" sample="1">
                <field name="reference"/>
                <field name="name"/>
                <field name="property_type_id"/>
                <field name="transaction_type"/>
                <field name="city"/>
                <field name="price" widget="monetary"/>
                <field name="rental_price" widget="monetary" optional="hide"/>
                <field name="state" widget="badge" decoration-success="state == 'available'" decoration-info="state == 'reserved'" decoration-danger="state == 'sold'"/>
                <field name="agent_id" widget="many2one_avatar_user"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Property Form View -->
    <record id="view_real_estate_property_form" model="ir.ui.view">
        <field name="name">real.estate.property.form</field>
        <field name="model">real.estate.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <header>
                    <button name="action_set_available" string="Set Available" type="object" invisible="state == 'available'" class="btn-primary"/>
                    <button name="action_set_reserved" string="Reserve" type="object" invisible="state in ['reserved', 'sold', 'rented']" class="btn-warning"/>
                    <button name="action_set_sold" string="Mark as Sold" type="object" invisible="state == 'sold' or transaction_type == 'rent'"/>
                    <button name="action_set_rented" string="Mark as Rented" type="object" invisible="state == 'rented' or transaction_type == 'sale'"/>
                    <field name="state" widget="statusbar" statusbar_visible="available,reserved,sold,rented"/>
                </header>
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_256'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Luxury Apartment in Downtown"/>
                        </h1>
                        <field name="reference" readonly="1"/>
                    </div>
                    <group>
                        <group name="basic_info" string="Basic Information">
                            <field name="property_type_id"/>
                            <field name="transaction_type"/>
                            <field name="agent_id" widget="many2one_avatar_user"/>
                            <field name="owner_id"/>
                            <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                        </group>
                        <group name="financial" string="Financial">
                            <field name="currency_id" invisible="1"/>
                            <field name="price" widget="monetary" invisible="transaction_type == 'rent'"/>
                            <field name="rental_price" widget="monetary" invisible="transaction_type == 'sale'"/>
                            <field name="rental_period" invisible="transaction_type == 'sale'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Property Details" name="details">
                            <group>
                                <group string="Dimensions">
                                    <field name="living_area"/>
                                    <field name="total_area"/>
                                    <field name="bedrooms"/>
                                    <field name="bathrooms"/>
                                </group>
                                <group string="Building Info">
                                    <field name="floor"/>
                                    <field name="total_floors"/>
                                    <field name="year_built"/>
                                </group>
                            </group>
                            <group>
                                <group string="Features">
                                    <field name="garage"/>
                                    <field name="garden"/>
                                    <field name="swimming_pool"/>
                                </group>
                                <group string="Amenities">
                                    <field name="elevator"/>
                                    <field name="balcony"/>
                                    <field name="furnished"/>
                                </group>
                            </group>
                            <group string="Description">
                                <field name="description" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Location" name="location">
                            <group>
                                <group>
                                    <field name="street" placeholder="Street..." />
                                    <field name="street2" placeholder="Street 2..." />
                                    <field name="city" placeholder="City" />
                                </group>
                                <group>
                                    <field name="state_id"  placeholder="State" options='{"no_open": True}'/>
                                    <field name="zip" placeholder="ZIP" />
                                    <field name="country_id" placeholder="Country" options='{"no_open": True}'/>
                                </group>
                            </group>
                        </page>
                        <page string="CRM" name="crm">
                            <field name="lead_ids" context="{'default_property_id': id, 'default_type': 'opportunity'}">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="stage_id"/>
                                    <field name="expected_revenue"/>
                                    <field name="probability"/>
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </list>
                            </field>
                        </page>
                        <page string="Visits" name="visits">
                            <field name="visit_ids" context="{'default_property_id': id}">
                                <list>
                                    <field name="name"/>
                                    <field name="visit_datetime"/>
                                    <field name="partner_id"/>
                                    <field name="state" widget="badge" decoration-info="state == 'planned'" decoration-success="state == 'done'"/>
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </list>
                            </field>
                        </page>
                        <page string="Rentals" name="rentals" invisible="transaction_type == 'sale'">
                            <field name="rental_contract_ids" context="{'default_property_id': id}">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="recurring_amount"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Commissions" name="commissions">
                            <field name="commission_ids" context="{'default_property_id': id}">
                                <list>
                                    <field name="name"/>
                                    <field name="agent_id" widget="many2one_avatar_user"/>
                                    <field name="commission_type"/>
                                    <field name="amount"/>
                                    <field name="state" widget="badge" decoration-success="state == 'paid'"/>
                                </list>
                            </field>
                        </page>
                        <page string="MLS Integration" name="mls" groups="real_estate_crm.group_real_estate_manager">
                            <group>
                                <field name="mls_external_id"/>
                                <field name="mls_status"/>
                                <field name="mls_last_sync"/>
                                <field name="mls_error_message"/>
                            </group>
                            <div class="alert alert-info" role="alert">
                                MLS portal integration will be available in Phase 2.
                                Supported portals: Idealista, Fotocasa, Habitaclia, pisos.com, yaencontre
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <!-- <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div> -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Property Kanban View -->
    <record id="view_real_estate_property_kanban" model="ir.ui.view">
        <field name="name">real.estate.property.kanban</field>
        <field name="model">real.estate.property</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="reference"/>
                <field name="property_type_id"/>
                <field name="city"/>
                <field name="price"/>
                <field name="rental_price"/>
                <field name="transaction_type"/>
                <field name="state"/>
                <field name="image_128"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('real.estate.property', 'image_128', record.id.raw_value)" alt="Property"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_record_subtitle">
                                    <field name="reference"/> - <field name="property_type_id"/>
                                </div>
                                <div class="o_kanban_record_subtitle">
                                    <field name="city"/>
                                </div>
                                <div>
                                    <field name="price" widget="monetary"/> 
                                    <t t-if="record.transaction_type.raw_value != 'sale'">
                                        / <field name="rental_price" widget="monetary"/>
                                    </t>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="state" widget="label" options="{'classes': {'available': 'success', 'reserved': 'warning', 'sold': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Property Search View -->
    <record id="view_real_estate_property_search" model="ir.ui.view">
        <field name="name">real.estate.property.search</field>
        <field name="model">real.estate.property</field>
        <field name="arch" type="xml">
            <search string="Properties">
                <field name="name" filter_domain="['|', ('name', 'ilike', self), ('reference', 'ilike', self)]"/>
                <field name="property_type_id"/>
                <field name="city"/>
                <field name="agent_id"/>
                <field name="owner_id"/>
                <separator/>
                <filter string="Available" name="available" domain="[('state', '=', 'available')]"/>
                <filter string="Reserved" name="reserved" domain="[('state', '=', 'reserved')]"/>
                <filter string="Sold" name="sold" domain="[('state', '=', 'sold')]"/>
                <filter string="Rented" name="rented" domain="[('state', '=', 'rented')]"/>
                <separator/>
                <filter string="For Sale" name="for_sale" domain="[('transaction_type', 'in', ['sale', 'both'])]"/>
                <filter string="For Rent" name="for_rent" domain="[('transaction_type', 'in', ['rent', 'both'])]"/>
                <separator/>
                <filter string="My Properties" name="my_properties" domain="[('agent_id', '=', uid)]"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Agent" name="agent" context="{'group_by': 'agent_id'}"/>
                    <filter string="Property Type" name="property_type" context="{'group_by': 'property_type_id'}"/>
                    <filter string="Transaction Type" name="transaction_type" context="{'group_by': 'transaction_type'}"/>
                    <filter string="State" name="state" context="{'group_by': 'state'}"/>
                    <filter string="City" name="city" context="{'group_by': 'city'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Property Action -->
    <record id="action_real_estate_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">real.estate.property</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first property
            </p>
            <p>
                Track and manage all your real estate properties in one place.
            </p>
        </field>
    </record>
</odoo>
