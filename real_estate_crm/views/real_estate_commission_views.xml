<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_real_estate_commission_tree" model="ir.ui.view">
        <field name="name">real.estate.commission.tree</field>
        <field name="model">real.estate.commission</field>
        <field name="arch" type="xml">
            <list string="Commissions">
                <field name="name"/>
                <field name="property_id"/>
                <field name="agent_id" widget="many2one_avatar_user"/>
                <field name="commission_type"/>
                <field name="base_amount" widget="monetary"/>
                <field name="rate"/>
                <field name="amount" widget="monetary" sum="Total"/>
                <field name="state" widget="badge" decoration-success="state == 'paid'" decoration-warning="state == 'confirmed'"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_real_estate_commission_form" model="ir.ui.view">
        <field name="name">real.estate.commission.form</field>
        <field name="model">real.estate.commission</field>
        <field name="arch" type="xml">
            <form string="Commission">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_mark_paid" string="Mark as Paid" type="object" invisible="state != 'confirmed'" class="btn-success"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ['paid', 'cancelled']"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group name="commission_info">
                            <field name="property_id"/>
                            <field name="agent_id" widget="many2one_avatar_user"/>
                            <field name="commission_type"/>
                            <field name="lead_id" invisible="commission_type != 'sale'"/>
                            <field name="contract_id" invisible="commission_type != 'rent'"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group name="calculation">
                            <field name="currency_id" invisible="1"/>
                            <field name="calculation_method"/>
                            <field name="base_amount" widget="monetary" invisible="calculation_method == 'fixed'"/>
                            <field name="rate" invisible="calculation_method == 'fixed'"/>
                            <field name="fixed_amount" widget="monetary" invisible="calculation_method == 'percentage'"/>
                            <field name="amount" widget="monetary" readonly="1" />
                        </group>
                    </group>
                    <group invisible="state != 'paid'">
                        <field name="payment_date"/>
                    </group>
                    <group>
                        <field name="notes" placeholder="Additional notes..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_real_estate_commission_search" model="ir.ui.view">
        <field name="name">real.estate.commission.search</field>
        <field name="model">real.estate.commission</field>
        <field name="arch" type="xml">
            <search string="Commissions">
                <field name="name"/>
                <field name="property_id"/>
                <field name="agent_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                <separator/>
                <filter string="Sale Commissions" name="sale" domain="[('commission_type', '=', 'sale')]"/>
                <filter string="Rental Commissions" name="rent" domain="[('commission_type', '=', 'rent')]"/>
                <separator/>
                <filter string="My Commissions" name="my_commissions" domain="[('agent_id', '=', uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="Agent" name="agent" context="{'group_by': 'agent_id'}"/>
                    <filter string="Property" name="property" context="{'group_by': 'property_id'}"/>
                    <filter string="Type" name="type" context="{'group_by': 'commission_type'}"/>
                    <filter string="State" name="state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_real_estate_commission" model="ir.actions.act_window">
        <field name="name">Commissions</field>
        <field name="res_model">real.estate.commission</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_confirmed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No commissions yet
            </p>
            <p>
                Commissions are automatically created when opportunities are won or rental contracts are activated.
            </p>
        </field>
    </record>
</odoo>
