<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_users_form_inherit_crm_base" model="ir.ui.view">
            <field name="name">res.users.form.inherit.crm.base</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page[@name='access_rights']" position="inside">
                    <group string="Sales Representative Info">
                        <field name="is_sales_representative"/>
                        <field name="referral_code" invisible="not is_sales_representative" required="is_sales_representative"/>
                        <field name="commission_percentage" invisible="not is_sales_representative"/>
                        <field name="company_currency_id" invisible="1"/>
                        <field name="total_commission_amount" invisible="not is_sales_representative" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                    </group>
                    <group string="Commercial Coverage" invisible="not is_sales_representative">
                        <field name="assigned_industry_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="assigned_state_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="assigned_country_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                </xpath>
                <xpath expr="//notebook" position="inside">
                    <page string="Referred Sales Orders" invisible="not is_sales_representative">
                        <field name="sale_order_ids" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="partner_id"/>
                                <field name="currency_id" column_invisible="True"/>
                                <field name="amount_total" sum="Total Sales"/>
                                <field name="commission_amount" sum="Total Commissions"/>
                                <field name="state"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="view_users_form_mail_inherit" model="ir.ui.view">
            <field name="name">res.users.form.mail.inherit</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="mail.view_users_form_mail"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='notification_type']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_users_form_mail_bot_inherit" model="ir.ui.view">
            <field name="name">res.users.form.mail.bot.inherit</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="mail_bot.res_users_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='odoobot_state']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_users_form_web_tour_inherit" model="ir.ui.view">
            <field name="name">res.users.form.web.tour.inherit.crm.base</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="web_tour.res_users_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='tour_enabled']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>


        <!-- Rename SystemBot Partner -->
        <record id="base.partner_root" model="res.partner">
            <field name="name">Asistente de EPG</field>
        </record>

        <!-- Rename SystemBot User -->
        <record id="base.user_root" model="res.users">
            <field name="name">Asistente de EPG</field>
        </record>
    </data>
</odoo>
