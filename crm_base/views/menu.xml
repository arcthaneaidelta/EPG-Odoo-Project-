<?xml version="1.0" encoding="utf-8"?>
<odoo>    
    <!-- Menu Sales Management-->
    <menuitem
        id="menu_sales_sales_management"  
        name="Sales"
        parent="sale.sale_menu_root"
        groups="sales_team.group_sale_salesman"
        sequence="4"
    />

    <record id="calendar.mail_menu_calendar" model="ir.ui.menu"> <!-- Calendar App Removed-->
        <field name="active">False</field>
    </record> 
    <record id="mail.menu_root_discuss" model="ir.ui.menu"> <!-- Discuss App Removed-->
        <field name="active">False</field>
    </record>
    <record id="spreadsheet_dashboard.spreadsheet_dashboard_menu_root" model="ir.ui.menu"> <!-- Dashboard App Removed-->
        <field name="active">False</field>
    </record> 
    <record id="utm.menu_link_tracker_root" model="ir.ui.menu"> <!-- Link Tracker App Removed-->
        <field name="active">False</field>
    </record> 
    <record id="hr.menu_hr_root" model="ir.ui.menu"> <!-- Hr(Employees) App Removed-->
        <field name="active">False</field>
    </record> 

    <!--               Sales Module's Menu Changes               -->
    <record id="sale.menu_sale_report" model="ir.ui.menu"> <!-- Reporting changes to Reports -->
        <field name="name">Reports</field>
    </record>
    <record id="crm.crm_menu_root" model="ir.ui.menu"> <!-- CRM changes to Pipeline -->
        <field name="name">Pipeline</field>
    </record>
    <record id="sale.menu_sale_general_settings" model="ir.ui.menu"> <!-- Configuration/Settings change to Sales/Settings-->
        <field name="parent_id" ref="sale.sale_menu_root"/>
        <field name="sequence">90</field>
        <field name="groups_id" eval="[(6, 0, [ref('sales_team.group_sale_manager')])]"/>
    </record>
    <record id="sale.menu_sale_quotations" model="ir.ui.menu"> <!-- Orders/Quotation change to Sales/Quotation-->
        <field name="parent_id" ref="sale.sale_menu_root"/>
        <field name="sequence">1</field>
        <field name="groups_id" eval="[(6, 0, [ref('sales_team.group_sale_salesman')])]"/>
    </record>
    <record id="sale.sale_order_menu" model="ir.ui.menu"> <!-- Orders sequence change-->
        <field name="sequence">2</field>
        <field name="groups_id" eval="[(6, 0, [ref('sales_team.group_sale_salesman')])]"/>

    </record>
    <record id="sale.menu_sale_order_invoice" model="ir.ui.menu">
        <field name="parent_id" ref="sale.sale_order_menu"/> <!-- Orders/Orders to invoice -->
        <field name="groups_id" eval="[(6, 0, [ref('sales_team.group_sale_salesman')])]"/>
    </record>
    <record id="sale.sales_team_config" model="ir.ui.menu">
        <field name="parent_id" ref="crm_base.menu_sales_sales_management"/> <!-- Sales Management/Sales Team -->
    </record>
    <record id="sale.sale_menu_config_activity_plan" model="ir.ui.menu">
        <field name="parent_id" ref="crm_base.menu_sales_sales_management"/> <!-- Sales Management/Activity Plans -->
    </record>
    <record id="sale.menu_product_categories" model="ir.ui.menu">
        <field name="parent_id" ref="sale.product_menu_catalog"/> <!-- Products/Product Categories -->
    </record>
    <record id="sale.menu_product_tags" model="ir.ui.menu">
        <field name="parent_id" ref="sale.product_menu_catalog"/> <!-- Products/Product Tags -->
    </record>

    <record id="sale.report_sales_team" model="ir.ui.menu"> <!-- Orders/Sales Team Removed -->
        <field name="active">False</field>
    </record>
    <record id="sale.res_partner_menu" model="ir.ui.menu"> <!-- Orders/Customers Removed -->
        <field name="active">False</field>
    </record>
    <record id="sale.menu_sale_invoicing" model="ir.ui.menu"> <!-- Sales/To Invoice Removed -->
        <field name="active">False</field>
    </record>
    <record id="sale.menu_sale_config" model="ir.ui.menu"> <!-- Configuration/To Invoice Removed -->
        <field name="active">False</field>
    </record>
    <record id="crm.crm_team_menu_config_activities" model="ir.ui.menu"> <!-- Configuration/Activities Removed -->
        <field name="active">False</field>
    </record>
    <record id="crm.menu_crm_config_lead" model="ir.ui.menu"> <!-- Configuration/Pipeline Removed -->
        <field name="active">False</field>
    </record>
    <record id="crm_iap_mine.crm_menu_lead_generation" model="ir.ui.menu"> <!-- Configuration/Lead Generation Removed -->
        <field name="active">False</field>
    </record>
</odoo>