<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_inherit_crm_base" model="ir.ui.view">
            <field name="name">res.partner.form.inherit.crm.base</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="client_type"/>
                    <field name="referral_code"/>
                    <field name="referrer_user_id"/>
                </xpath>


            </field>
        </record>

        <record id="res_partner_form_disable_sms" model="ir.ui.view">
            <field name="name">res.partner.form.disable.sms</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='phone']" position="attributes">
                    <attribute name="options">{'enable_sms': False}</attribute>
                </xpath>
                <xpath expr="//field[@name='mobile']" position="attributes">
                    <attribute name="options">{'enable_sms': False}</attribute>
                </xpath>
            </field>
        </record>

        <record id="res_partner_form_remove_website_placeholder" model="ir.ui.view">
            <field name="name">res.partner.form.remove.website.placeholder</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='website']" position="attributes">
                    <attribute name="placeholder"/>
                </xpath>


            </field>
        </record>


        <record id="res_partner_form_add_dob" model="ir.ui.view">
            <field name="name">res.partner.form.add.dob</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='category_id']" position="before">
                    <field name="date_of_birth"/>
                    <field name="nationality_id" options="{'no_create': True, 'no_open': True}"/>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="Contact Details" name="additional_contact_info">
                        <group>
                            <group string="Additional Emails">
                                <field name="additional_email_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="email" widget="email"/>
                                        <field name="note" placeholder="Personal, Work, etc."/>
                                    </list>
                                </field>
                            </group>
                            <group string="Additional Phone Numbers">
                                <field name="additional_phone_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="phone" widget="phone" options="{'enable_sms': False}"/>
                                        <field name="note" placeholder="Emergency, Secondary, etc."/>
                                    </list>
                                </field>
                            </group>
                        </group>
                    </page>
                </xpath>

                <!-- Enforce Address Order: Street 1, 2, State, City, Zip, Country -->
                <xpath expr="//div[hasclass('o_address_format')]" position="inside">
                    <field name="street" position="move" />
                    <field name="street2" position="move" />
                    <field name="state_id" position="move" />
                    <field name="city" position="move" />
                    <field name="zip" position="move" />
                    <field name="country_id" position="move" />
                </xpath>

            </field>
        </record>

        <!-- Search View Inheritance for Filters and Groups -->
        <record id="view_res_partner_filter_inherit_crm_base" model="ir.ui.view">
            <field name="name">res.partner.select.inherit.crm.base</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='inactive']" position="before">
                    <filter string="Active Contacts" name="active_contacts" domain="[('active', '=', True)]"/>
                    <filter string="Inactive Contacts" name="inactive_contacts" domain="[('active', '=', False)]"/>
                    <separator/>
                </xpath>
                <xpath expr="//group" position="inside">
                    <filter string="Creation Period" name="group_create_date" context="{'group_by': 'create_date'}"/>
                    <filter string="Sector" name="group_industry" context="{'group_by': 'industry_id'}"/>
                    <filter string="City" name="group_city" context="{'group_by': 'city'}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
