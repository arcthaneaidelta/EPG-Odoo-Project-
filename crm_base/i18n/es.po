#. module: crm_base
#: model:mail.template,body_html:crm_base.email_template_welcome_new_customer
msgid ""
"<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; line-height: 1.6; color: #333;\">\n"
"                \n"
"                <div style=\"background-color: #005082; padding: 25px; text-align: center;\">\n"
"                    <h1 style=\"color: white; margin: 0; font-size: 24px;\">Bienvenido a EPG</h1>\n"
"                </div>\n"
"\n"
"                <div style=\"padding: 30px; background-color: #ffffff; border: 1px solid #ddd;\">\n"
"                    <p style=\"font-size: 16px;\">Hola <strong><t t-out=\"object.name\"/></strong>,</p>\n"
"                    \n"
"                    <p>Gracias por completar este primer paso. Hemos recibido correctamente tu registro.</p>\n"
"                    \n"
"                    <p>Debido al alto volumen de solicitudes, nuestro equipo está atendiendo cada caso de forma individualizada para poder realizar un estudio personalizado, garantizando así la máxima calidad en el análisis.</p>\n"
"                    \n"
"                    <p>En breve nos pondremos en contacto contigo para informarte del estado de tu solicitud y los siguientes pasos a seguir.</p>\n"
"                    \n"
"                    <p style=\"margin-top: 30px;\">Gracias por tu confianza.</p>\n"
"                    \n"
"                    <p style=\"color: #005082; font-weight: bold;\">El equipo de Eficiencia y Productividad Global</p>\n"
"                </div>\n"
"\n"
"                <div style=\"background-color: #f4f4f4; padding: 15px; text-align: center; color: #777; font-size: 12px; border: 1px solid #ddd; border-top: none;\">\n"
"                    <p style=\"margin: 0;\">© 2026 Eficiencia y Productividad Global S.L.U.</p>\n"
"                    <p style=\"margin: 5px 0 0 0;\">C/ Lepant 270, Nexus Coworking, España</p>\n"
"                </div>\n"
"\n"
"            </div>\n"
"        "
msgstr ""

#. module: crm_base
#: model:mail.template,body_html:crm_base.email_template_new_lead_notification
msgid ""
"<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;\">\n"
"                \n"
"                <div style=\"background-color: #005082; padding: 20px; text-align: center;\">\n"
"                    <h1 style=\"color: white; margin: 0;\">Notificación de Nuevo Lead</h1>\n"
"                </div>\n"
"\n"
"                <div style=\"padding: 20px; background-color: #f9f9f9;\">\n"
"                    <h2 style=\"color: #005082;\">\n"
"                        ¡Se ha creado un nuevo lead desde el sitio web!\n"
"                    </h2>\n"
"\n"
"                    <table style=\"width: 100%; border-collapse: collapse; margin-top: 20px;\">\n"
"\n"
"                        <tr style=\"background-color: #f0f0f0;\">\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd; font-weight: bold;\">\n"
"                                Asunto del Lead\n"
"                            </td>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd;\">\n"
"                                <t t-out=\"object.name or 'N/D'\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                        <tr>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd; font-weight: bold;\">\n"
"                                Nombre del Contacto\n"
"                            </td>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd;\">\n"
"                                <t t-out=\"object.contact_name or object.visitor_name or 'N/D'\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                        <tr style=\"background-color: #f0f0f0;\">\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd; font-weight: bold;\">\n"
"                                Correo Electrónico\n"
"                            </td>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd;\">\n"
"                                <t t-out=\"object.email_from or 'N/D'\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                        <tr>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd; font-weight: bold;\">\n"
"                                Teléfono\n"
"                            </td>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd;\">\n"
"                                <t t-out=\"object.phone or 'N/D'\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                        <tr style=\"background-color: #f0f0f0;\">\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd; font-weight: bold;\">\n"
"                                Empresa\n"
"                            </td>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd;\">\n"
"                                <t t-out=\"object.partner_name or 'N/D'\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                        <tr>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd; font-weight: bold;\">\n"
"                                Tipo de Origen\n"
"                            </td>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd;\">\n"
"                                <t t-out=\"object.source_type or 'N/D'\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                        <tr style=\"background-color: #f0f0f0;\">\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd; font-weight: bold;\">\n"
"                                Descripción\n"
"                            </td>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd;\">\n"
"                                <t t-out=\"object.description or 'N/D'\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                        <tr>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd; font-weight: bold;\">\n"
"                                Fecha de Creación\n"
"                            </td>\n"
"                            <td style=\"padding: 10px; border: 1px solid #ddd;\">\n"
"                                <t t-out=\"object.create_date\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"\n"
"                    </table>\n"
"                </div>\n"
"\n"
"                <div style=\"background-color: #333; padding: 15px; text-align: center; color: white;\">\n"
"                    <p style=\"margin: 0;\">\n"
"                        Este es un mensaje automático generado por el sistema CRM.\n"
"                    </p>\n"
"                </div>\n"
"\n"
"            </div>\n"
"        "
msgstr ""


