<odoo>
    <record id="view_move_form" model="ir.ui.view">
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref'][last()]" position="after">
                <field name="thirdparty_invoice" invisible="1" />
                <field
                    name="thirdparty_number"
                    invisible="1"
                    readonly="state != 'draft'"
                />
            </xpath>
        </field>
    </record>


    <record id="l10n_es_aeat.l10n_es_aeat_certificate_menu" model="ir.ui.menu"> <!-- Customers/Product Removed -->
        <field name="active">False</field>
    </record>
    <record id="l10n_es_aeat.menu_l10n_es_aeat_map_tax_code" model="ir.ui.menu"> <!-- Tax Mapping Removed -->
        <field name="active">False</field>
    </record>
    <record id="l10n_es_aeat.aeat_tax_agency_menu" model="ir.ui.menu"> <!-- Tax Agency Removed -->
        <field name="active">False</field>
    </record>
    <record id="l10n_es_aeat.menu_aeat_export_config" model="ir.ui.menu"> <!-- BOE Export Configuration Removed -->
        <field name="active">False</field>
    </record>
</odoo>
