        <!-- BASE CRM PLAN PRODUCTS -->
        <!-- ===================== -->
        
        <!-- CRM Early Adopter Monthly Product - €25.00/mo -->
        <record id="product_crm_early_adopter_monthly" model="product.product">
            <field name="name">Usuarios pioneros de CRM (mensual)</field>
            <field name="default_code">SAAS_CRM_EARLY_MONTHLY</field>
            <field name="list_price">34.90</field>
            <field name="type">service</field>
            <field name="categ_id" ref="product.product_category_all"/>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="False"/>
            <field name="invoice_policy">order</field>
            <field name="description">CRM Early Adopter plan - Monthly billing. Includes 3 users, 3GB storage, Daily automatic backups, and Accounting module for life.</field>
        </record>
        
