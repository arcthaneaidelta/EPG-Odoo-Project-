<?xml version="1.0" encoding="UTF-8"?>

<odoo>
	
    <record id="view_res_users_form" model="ir.ui.view">
        <field name="name">res.users.form</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif" />
        <field name="arch" type="xml">
             <xpath expr="//field[@name='tz']" position="after">
                <field name="sidebar_type" readonly="0"/>
            </xpath>
        </field>
    </record>

    <record id="custom_remove_about_section" model="ir.ui.view">
        <field name="name">res.config.settings.form.remove.about</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Remove the about div -->
            <xpath expr="//div[@id='about']" position="replace"/>
        </field>
    </record>

</odoo>
