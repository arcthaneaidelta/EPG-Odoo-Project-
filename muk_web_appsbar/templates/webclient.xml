<?xml version="1.0" encoding="UTF-8"?>

<odoo>
	
	<template id="webclient_bootstrap" name="Web Client" inherit_id="web.webclient_bootstrap">
        <xpath expr="//t[@t-set='body_classname']" position="after">
        	<t t-set="body_sidebar_classname" t-value="'mk_sidebar_type_' + (request.env.user.sidebar_type if 'sidebar_type' in request.env.user else 'large')"/>
            <t t-set="body_classname" t-value="'%s %s' % (body_classname, body_sidebar_classname)"/>
        </xpath>
        <xpath expr="//t[@t-if=&quot;request.cookies.get('color_scheme') == 'dark'&quot;]" position="attributes">
            <attribute name="t-if">request.cookies.get('color_scheme') != 'light'</attribute>
        </xpath>
    </template>
    <template id="web_layout_favicon_inherit" inherit_id="web.layout">
        <xpath expr="//link[@rel='shortcut icon']" position="replace">
            <link type="image/x-icon" rel="shortcut icon" href="/muk_web_appsbar/static/src/img/favicon.png"/>
        </xpath>
    </template>
</odoo>
