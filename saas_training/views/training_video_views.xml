<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_saas_training_video_form" model="ir.ui.view">
        <field name="name">saas.training.video.form</field>
        <field name="model">saas.training.video</field>
        <field name="arch" type="xml">
            <form string="Training Video">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_video" type="object" class="oe_stat_button" icon="fa-youtube-play" string="Mirar"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="video_url" widget="url"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_saas_training_video_list" model="ir.ui.view">
        <field name="name">saas.training.video.list</field>
        <field name="model">saas.training.video</field>
        <field name="arch" type="xml">
            <list string="Vídeos de formación">
                <header>
                    <button name="action_push_to_tenants" string="Empujar a los inquilinos" type="object" class="oe_highlight"/>
                </header>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category"/>
                <field name="video_url" widget="url"/>
            </list>
        </field>
    </record>

    <record id="view_saas_training_video_kanban" model="ir.ui.view">
        <field name="name">saas.training.video.kanban</field>
        <field name="model">saas.training.video</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category">
                <field name="name"/>
                <field name="category"/>
                <field name="video_url"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click oe_kanban_card">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="category"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <a t-att-href="record.video_url.raw_value" target="_blank" class="btn btn-sm btn-primary">Mirar</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_saas_training_video" model="ir.actions.act_window">
        <field name="name">Vídeos de formación</field>
        <field name="res_model">saas.training.video</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_training_root"
              name="Capacitación"
              web_icon="muk_web_appsbar,static/description/training.svg"
              sequence="6"/>

    <menuitem id="menu_training_videos"
              name="Vídeos"
              parent="menu_training_root"
              action="action_saas_training_video"
              sequence="10"/>
</odoo>
