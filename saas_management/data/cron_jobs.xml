<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Daily Subscription Expiry Check (Active -> Grace -> Suspended) -->
        <record id="cron_subscription_expiry" model="ir.cron">
            <field name="name">SaaS: Process Subscription Expiry</field>
            <field name="model_id" ref="model_saas_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_subscription_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 01:00:00')"/>
            <field name="active">True</field>
            <field name="priority">5</field>
        </record>

        <!-- Daily cron: remove cancelled add-ons after next_renewal_date -->
        <record id="cron_expire_cancelled_addons" model="ir.cron">
            <field name="name">SaaS: Expire Cancelled Add-ons</field>
            <field name="model_id" ref="model_saas_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_cancelled_addons()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 02:00:00')"/>
            <field name="active">True</field>
            <field name="priority">10</field>
        </record>

        <!-- Daily cron: auto renew subscriptions and charge saved cards -->
        <record id="cron_auto_renew_subscriptions" model="ir.cron">
            <field name="name">SaaS: Auto Renew Subscriptions</field>
            <field name="model_id" ref="model_saas_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_renew_subscriptions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 03:00:00')"/>
            <field name="active">True</field>
            <field name="priority">15</field>
        </record>

    </data>
</odoo>
