<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Sequence for Subscription Reference -->
        <record id="seq_saas_subscription" model="ir.sequence">
            <field name="name">SaaS Subscription</field>
            <field name="code">saas.subscription</field>
            <field name="prefix">SAAS-</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
        </record>

        <!-- CRM Early Adopter Plans -->
        <record id="plan_crm_early_annual" model="saas.plan">
            <field name="name">CRM Early Adopter (Annual)</field>
            <field name="sequence">1</field>
            <field name="plan_type">crm_early</field>
            <field name="billing_cycle">annual</field>
            <field name="price_annual">358.00</field>
            <field name="price_monthly">0</field>
            <field name="included_users">3</field>
            <field name="included_storage_gb">3</field>
            <field name="is_early_adopter">True</field>
            <field name="early_adopter_limit">1000</field>
            <field name="module_names">crm,account,saas_client</field>
            <field name="description">&lt;p&gt;Early Adopter Special: First 1000 customers&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;CRM Base included&lt;/li&gt;
&lt;li&gt;Accounting/Gestoría module included for life&lt;/li&gt;
&lt;li&gt;3 users included&lt;/li&gt;
&lt;li&gt;3 GB storage&lt;/li&gt;
&lt;li&gt;Daily automatic backups&lt;/li&gt;
&lt;li&gt;Priority Support&lt;/li&gt;
&lt;li&gt;Price protected while subscription active&lt;/li&gt;
&lt;/ul&gt;</field>
        </record>

        <record id="plan_crm_early_monthly" model="saas.plan">
            <field name="name">CRM Early Adopter (Monthly)</field>
            <field name="sequence">2</field>
            <field name="plan_type">crm_early</field>
            <field name="billing_cycle">monthly</field>
            <field name="price_annual">0</field>
            <field name="price_monthly">34.90</field>
            <field name="included_users">3</field>
            <field name="included_storage_gb">3</field>
            <field name="is_early_adopter">True</field>
            <field name="early_adopter_limit">1000</field>
            <field name="module_names">crm,account,saas_client</field>
            <field name="description">&lt;p&gt;Early Adopter Special: First 1000 customers&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;CRM Base included&lt;/li&gt;
&lt;li&gt;Accounting/Gestoría module included for life&lt;/li&gt;
&lt;li&gt;3 users included&lt;/li&gt;
&lt;li&gt;3 GB storage&lt;/li&gt;
&lt;li&gt;Daily automatic backups&lt;/li&gt;
&lt;li&gt;Priority Support&lt;/li&gt;
&lt;li&gt;Price protected while subscription active&lt;/li&gt;
&lt;/ul&gt;</field>
        </record>

        <!-- CRM Official Plans -->
        <record id="plan_crm_official_annual" model="saas.plan">
            <field name="name">CRM Official (Annual)</field>
            <field name="sequence">10</field>
            <field name="plan_type">crm_official</field>
            <field name="billing_cycle">annual</field>
            <field name="price_annual">598.00</field>
            <field name="price_monthly">0</field>
            <field name="included_users">3</field>
            <field name="included_storage_gb">3</field>
            <field name="is_early_adopter">False</field>
            <field name="module_names">crm,crm_base,saas_client</field>
            <field name="description">&lt;p&gt;Official CRM Plan&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;CRM Base included&lt;/li&gt;
&lt;li&gt;3 users included&lt;/li&gt;
&lt;li&gt;3 GB storage&lt;/li&gt;
&lt;li&gt;Daily automatic backups&lt;/li&gt;
&lt;li&gt;Standard Support&lt;/li&gt;
&lt;/ul&gt;</field>
        </record>

        <record id="plan_crm_official_monthly" model="saas.plan">
            <field name="name">CRM Official (Monthly)</field>
            <field name="sequence">11</field>
            <field name="plan_type">crm_official</field>
            <field name="billing_cycle">monthly</field>
            <field name="price_annual">0</field>
            <field name="price_monthly">59.90</field>
            <field name="included_users">3</field>
            <field name="included_storage_gb">3</field>
            <field name="is_early_adopter">False</field>
            <field name="module_names">crm,crm_base,saas_client</field>
            <field name="description">&lt;p&gt;Official CRM Plan&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;CRM Base included&lt;/li&gt;
&lt;li&gt;3 users included&lt;/li&gt;
&lt;li&gt;3 GB storage&lt;/li&gt;
&lt;li&gt;Daily automatic backups&lt;/li&gt;
&lt;li&gt;Standard Support&lt;/li&gt;
&lt;/ul&gt;</field>
        </record>

        <!-- System Parameters -->
        <record id="param_base_domain" model="ir.config_parameter">
            <field name="key">saas.base_domain</field>
            <field name="value">abc.com</field>
        </record>

        <record id="param_grace_period_days" model="ir.config_parameter">
            <field name="key">saas.grace_period_days</field>
            <field name="value">30</field>
        </record>

        <record id="param_auto_provision" model="ir.config_parameter">
            <field name="key">saas.auto_provision_on_payment</field>
            <field name="value">True</field>
        </record>

    </data>
</odoo>
