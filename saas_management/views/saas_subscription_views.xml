<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Subscription List View -->
        <record id="view_saas_subscription_tree" model="ir.ui.view">
            <field name="name">saas.subscription.tree</field>
            <field name="model">saas.subscription</field>
            <field name="arch" type="xml">
                <list string="Subscriptions" decoration-success="state=='active'" decoration-danger="state=='suspended'" decoration-warning="state=='grace_period'">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="company_name"/>
                    <field name="plan_id"/>
                    <field name="billing_cycle"/>
                    <field name="is_early_adopter"/>
                    <field name="price"/>
                    <field name="state"/>
                    <field name="activation_date"/>
                    <field name="expiration_date"/>
                    
                </list>
            </field>
        </record>

        <!-- Subscription Form View -->
        <record id="view_saas_subscription_form" model="ir.ui.view">
            <field name="name">saas.subscription.form</field>
            <field name="model">saas.subscription</field>
            <field name="arch" type="xml">
                <form string="Subscription">
                    <header>
                        <!-- Renew/Upgrade moved to Portal -->

                        <button name="action_open_tenant" string="Open Tenant" type="object" class="oe_highlight" invisible="state not in ('active', 'suspended')"/>
                        <button name="action_cancel_subscription" string="Cancel" type="object" invisible="state not in ('active', 'suspended')"/>
                        <button name="action_reactivate_subscription" string="Reactivate" type="object" class="oe_highlight" invisible="state != 'grace_period'"/>
                        <button name="action_suspend_subscription" string="Suspend" type="object" invisible="state != 'active'"/>
                        <field name="state"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="partner_id"/>
                                <field name="company_name"/>
                                <field name="plan_id"/>
                                <field name="billing_cycle"/>
                                <field name="auto_renew"/>
                                <field name="is_early_adopter" readonly="1"/>
                                <field name="price"/>
                                <field name="order_id"/>
                            </group>
                            <group>
                                <field name="database_name" readonly="1"/>
                                <field name="subdomain" readonly="1"/>
                                <field name="tenant_url" widget="url" readonly="1"/>
                                <field name="activation_date" readonly="1"/>
                                <field name="expiration_date"/>
                                <field name="next_billing_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Quotas &amp; Add-ons">
                                <group>
                                    <group string="Users">
                                        <field name="extra_users" readonly="1"/>
                                        <field name="total_users" readonly="1"/>
                                    </group>
                                    <group string="Storage">
                                        <field name="extra_storage_gb" readonly="1"/>
                                        <field name="total_storage_gb" readonly="1"/>
                                    </group>
                                </group>
                                <separator string="Add-on Records"/>
                                <field name="addon_ids" nolabel="1">
                                    <list decoration-success="state=='active'"
                                          decoration-warning="state=='cancelled'"
                                          decoration-muted="state=='expired'">
                                        <field name="addon_type"/>
                                        <field name="quantity"/>
                                        <field name="monthly_price"/>
                                        <field name="total_monthly" readonly="1"/>
                                        <!-- <field name="proration_amount" readonly="1"/> -->
                                        <field name="purchase_date" readonly="1"/>
                                        <field name="next_renewal_date"/>
                                        <field name="state" readonly="1"/>
                                        <button name="action_cancel_addon"
                                                string="Cancel"
                                                type="object"
                                                icon="fa-times-circle"
                                                invisible="state != 'active'"/>
                                        <button name="action_reactivate_addon"
                                                string="Reactivate"
                                                type="object"
                                                icon="fa-undo"
                                                invisible="state != 'cancelled'"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Modules">
                                <group>
                                    <field name="accounting_module"/>
                                    <field name="real_estate_module"/>
                                </group>
                            </page>
                            <page string="Grace Period" invisible="state not in ('grace_period', 'pending_deletion')">
                                <group>
                                    <field name="grace_period_start"/>
                                    <field name="grace_period_end"/>
                                    <field name="deletion_scheduled_date"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Subscription Action -->
        <record id="action_saas_subscription" model="ir.actions.act_window">
            <field name="name">Subscriptions</field>
            <field name="res_model">saas.subscription</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_saas_subscription"
                  name="All Subscriptions"
                  parent="menu_saas_subscriptions"
                  action="action_saas_subscription"
                  sequence="10"/>

    </data>
</odoo>
