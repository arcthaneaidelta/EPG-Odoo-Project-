<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Plan List View -->
        <record id="view_saas_plan_tree" model="ir.ui.view">
            <field name="name">saas.plan.tree</field>
            <field name="model">saas.plan</field>
            <field name="arch" type="xml">
                <list string="SaaS Plans">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="plan_type"/>
                    <field name="billing_cycle"/>
                    <field name="price_monthly"/>
                    <field name="price_annual"/>
                    <field name="is_early_adopter"/>
                    <field name="early_adopter_count" optional="hide"/>
                    <field name="early_adopter_available" optional="hide"/>
                    <field name="active_subscription_count"/>
                </list>
            </field>
        </record>

        <!-- Wizard Action -->
        <record id="action_saas_limit_wizard" model="ir.actions.act_window">
            <field name="name">Update Limits</field>
            <field name="res_model">saas.limit.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Plan Form View -->
        <record id="view_saas_plan_form" model="ir.ui.view">
            <field name="name">saas.plan.form</field>
            <field name="model">saas.plan</field>
            <field name="arch" type="xml">
                <form string="SaaS Plan">
                    <header>
                        <button name="%(action_saas_limit_wizard)d" string="Update Limits" type="action" 
                                groups="base.group_system" invisible="not is_early_adopter"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_subscriptions" type="object" class="oe_stat_button" icon="fa-users">
                                <field name="active_subscription_count" widget="statinfo" string="Active"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="plan_type"/>
                                <field name="billing_cycle"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="price_monthly" invisible="billing_cycle == 'annual'"/>
                                <field name="price_annual" invisible="billing_cycle == 'monthly'"/>
                                <field name="sequence"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Quotas &amp; Limits">
                                <group>
                                    <group>
                                        <field name="included_users"/>
                                        <field name="included_storage_gb"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Modules">
                                <group>
                                    <field name="module_names" placeholder="e.g., crm,account,real_estate"/>
                                    <field name="module_ids" widget="many2many_tags"/>
                                </group>
                            </page>
                            <page string="Early Adopter">
                                <group>
                                    <field name="is_early_adopter"/>
                                    <field name="early_adopter_price" invisible="not is_early_adopter"/>
                                    <field name="early_adopter_limit" invisible="not is_early_adopter"/>
                                    <field name="early_adopter_count" invisible="not is_early_adopter"/>
                                    <field name="early_adopter_available" invisible="not is_early_adopter"/>
                                </group>
                            </page>
                            <page string="Description">
                                <field name="description" widget="html"/>
                                <field name="features" placeholder="One feature per line"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Plan Action -->
        <record id="action_saas_plan" model="ir.actions.act_window">
            <field name="name">Subscription Plans</field>
            <field name="res_model">saas.plan</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_saas_plan"
                  name="Subscription Plans"
                  parent="menu_saas_plans"
                  action="action_saas_plan"
                  sequence="10"/>

    </data>
</odoo>
