<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Form View -->
        <record id="view_saas_suggestion_form" model="ir.ui.view">
            <field name="name">saas.suggestion.form</field>
            <field name="model">saas.suggestion</field>
            <field name="arch" type="xml">
                <form string="Tenant Suggestion">
                    <header>
                        <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="subscription_id"/>
                                <field name="database_name"/>
                                <field name="customer_id"/>
                            </group>
                            <group>
                                <field name="email"/>
                                <field name="create_date" string="Date Submitted" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="suggestion_text"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_saas_suggestion_tree" model="ir.ui.view">
            <field name="name">saas.suggestion.tree</field>
            <field name="model">saas.suggestion</field>
            <field name="arch" type="xml">
                <list string="Tenant Suggestions" decoration-info="state == 'new'" decoration-success="state == 'resolved'" decoration-muted="state == 'reviewed'">
                    <field name="database_name"/>
                    <field name="email"/>
                    <field name="create_date" string="Date Submitted"/>
                    <field name="state" widget="badge" decoration-info="state == 'new'" decoration-success="state == 'resolved'" decoration-muted="state == 'reviewed'"/>
                </list>
            </field>
        </record>

        <!-- Action -->
        <record id="action_saas_suggestion" model="ir.actions.act_window">
            <field name="name">Tenant Suggestions</field>
            <field name="res_model">saas.suggestion</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                No suggestions yet!
              </p>
              <p>
                Suggestions submitted by tenants will appear here.
              </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_saas_suggestion"
                  name="Suggestions"
                  parent="menu_saas_root"
                  action="action_saas_suggestion"
                  sequence="25"/>

    </data>
</odoo>
