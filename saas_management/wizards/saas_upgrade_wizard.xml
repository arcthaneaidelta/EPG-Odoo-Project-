<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_saas_upgrade_wizard_form" model="ir.ui.view">
            <field name="name">saas.upgrade.wizard.form</field>
            <field name="model">saas.upgrade.wizard</field>
            <field name="arch" type="xml">
                <form string="Upgrade Tenant Modules">
                    <group>
                        <field name="module_names"/>
                    </group>
                    <footer>
                        <button name="action_upgrade" string="Start Upgrade" type="object" class="btn-primary" data-hotkey="q"/>
                        <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_saas_upgrade_wizard" model="ir.actions.act_window">
            <field name="name">Upgrade Modules</field>
            <field name="res_model">saas.upgrade.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="saas_management.model_saas_subscription"/>
            <field name="binding_view_types">list</field>
        </record>
    </data>
</odoo>
