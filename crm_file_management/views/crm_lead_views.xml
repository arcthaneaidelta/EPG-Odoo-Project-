<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_view_form_inherit_file" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.file</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_files" type="object" class="oe_stat_button" icon="fa-folder-open" invisible="file_count == 0">
                    <field name="file_count" widget="statinfo" string="Files"/>
                </button>
            </div>
            <header position="inside">
                <button name="action_create_file" type="object" string="Create File" class="oe_highlight"/>
            </header>
        </field>
    </record>
</odoo>
