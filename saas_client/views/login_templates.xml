<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit web.login_layout to perfectly target the layout wrapper -->
    <template id="saas_client_login_layout" inherit_id="web.login_layout" name="SaaS Clean Login Layout">
        
        <!-- 1. Remove the "Powered by Odoo" and "Manage Databases" bottom block completely -->
        <xpath expr="//div[hasclass('border-top', 'mt-4', 'pt-3')]" position="replace">
            <!-- Completely eliminated -->
        </xpath>
        
        <!-- 2. Inject Dark Theme CSS directly before the container -->
        <xpath expr="//div[hasclass('container', 'py-5')]" position="before">
            <style>
                /* Muk Web Appsbar Dark Theme Integration for Login */
                html, body, body.bg-100 {
                    background-color: #081028 !important;
                    color: #c9d6e8 !important;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    min-height: 100vh;
                    margin: 0;
                }
                
                #wrapwrap {
                    background: transparent !important;
                    display: flex;
                    width: 100%;
                    align-items: center;
                }
                
                main {
                    width: 100%;
                }

                .card {
                    background-color: #0d1a3a !important;
                    border: 1px solid #1a2f5a !important;
                    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5) !important;
                    border-radius: 12px !important;
                    padding: 1rem;
                }
                
                .card-body {
                    background-color: transparent !important;
                }

                input.form-control, .form-select {
                    background-color: #0a1428 !important;
                    border: 1px solid #1a2f5a !important;
                    color: #c9d6e8 !important;
                    border-radius: 8px !important;
                    padding: 12px 16px !important;
                    transition: border-color 0.2s, box-shadow 0.2s;
                }

                input.form-control:focus {
                    border-color: #0088ff !important;
                    box-shadow: 0 0 0 2px rgba(0, 136, 255, 0.2) !important;
                    background-color: #0a1428 !important;
                    color: #ffffff !important;
                }
                
                input.form-control::placeholder, .form-select::placeholder {
                    color: #8aaac8 !important;
                    opacity: 0.8 !important;
                }
                
                label {
                    color: #e8edf5 !important;
                    font-weight: 500 !important;
                }

                .btn-primary {
                    background-color: #0088ff !important;
                    color: #03080f !important;
                    border: none !important;
                    border-radius: 8px !important;
                    font-weight: 700 !important;
                    padding: 12px !important;
                    transition: all 0.2s ease !important;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                }

                .btn-primary:hover {
                    background-color: #33ddff !important;
                    transform: translateY(-2px);
                    box-shadow: 0 4px 15px rgba(0, 136, 255, 0.4) !important;
                    color: #03080f !important;
                }
                
                /* Fix Select Button and Input Group */
                .input-group {
                    display: flex !important;
                    align-items: stretch !important;
                }
                .input-group .form-control {
                    border-top-right-radius: 0 !important;
                    border-bottom-right-radius: 0 !important;
                    border-right: none !important;
                    margin-bottom: 0 !important;
                }
                .input-group .btn-secondary {
                    background-color: #1a2f5a !important;
                    border: 1px solid #1a2f5a !important;
                    color: #e8edf5 !important;
                    border-top-left-radius: 0 !important;
                    border-bottom-left-radius: 0 !important;
                    border-top-right-radius: 8px !important;
                    border-bottom-right-radius: 8px !important;
                    display: flex !important;
                    align-items: center !important;
                    padding: 0 16px !important;
                    margin: 0 !important;
                    height: auto !important; /* ensures it stretches to match input height */
                    line-height: normal !important;
                }

                .input-group .btn-secondary:hover {
                    background-color: #274075 !important;
                    color: #ffffff !important;
                }

                a, .btn-link {
                    color: #0088ff !important;
                    text-decoration: none !important;
                }

                a:hover, .btn-link:hover {
                    color: #33ddff !important;
                }

                .text-muted, .small {
                    color: #5a7099 !important;
                }
                
                /* Override default Odoo container layout */
                .container.py-5 {
                    padding-top: 2rem !important;
                    padding-bottom: 2rem !important;
                }
                
                .border-bottom, .border-top {
                    border-color: #1a2f5a !important;
                }
            </style>
        </xpath>
    </template>
</odoo>
