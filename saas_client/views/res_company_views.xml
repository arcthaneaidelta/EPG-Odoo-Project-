<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_saas_onboarding" model="ir.ui.view">
        <field name="name">res.company.form.saas.onboarding</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Onboarding Data" name="saas_onboarding_data">
                    <group>
                        <group string="Client Profile">
                            <field name="saas_client_type" readonly="1"/>
                            <field name="saas_activity_type" readonly="1"/>
                            <field name="saas_main_objective" readonly="1"/>
                            <field name="saas_user_count_expected" readonly="1"/>
                        </group>
                        <group string="Sales &amp; Accounting setup">
                            <field name="saas_use_quotations" readonly="1"/>
                            <field name="saas_use_sales_followup" readonly="1"/>
                            <field name="saas_issue_invoices" readonly="1"/>
                            <field name="saas_record_supplier_invoices" readonly="1"/>
                            <field name="saas_use_accounting" readonly="1"/>
                            <field name="saas_accounting_handler" readonly="1"/>
                        </group>
                        <group string="Other Selections">
                            <field name="saas_wants_ai" readonly="1"/>
                            <field name="saas_import_strategy" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
