#. module: crm_automation_engine
#: model:mail.template,body_html:crm_automation_engine.email_template_invoice_auto_send
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>Dear <t t-out=\"object.partner_id.name\"/>,</p>\n"
"                <p>Please find attached invoice <strong><t t-out=\"object.name\"/></strong> for <t t-out=\"format_amount(object.amount_total, object.currency_id)\"/>.</p>\n"
"                <p>Due date: <t t-out=\"object.invoice_date_due\"/></p>\n"
"                <p>Best regards,</p>\n"
"                <p><t t-out=\"object.company_id.name\"/></p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>Estimado/a <t t-out=\"object.partner_id.name\"/>,</p>\n"
"                <p>Adjunto encontrará la factura <strong><t t-out=\"object.name\"/></strong> por <t t-out=\"format_amount(object.amount_total, object.currency_id)\"/>.</p>\n"
"                <p>Fecha de vencimiento: <t t-out=\"object.invoice_date_due\"/></p>\n"
"                <p>Atentamente,</p>\n"
"                <p><t t-out=\"object.company_id.name\"/></p>\n"
"            </div>\n"
"        "

#. module: crm_automation_engine
#: model:mail.template,body_html:crm_automation_engine.email_template_lead_confirmation
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>Hello,</p>\n"
"                <p>Thank you for your interest! We have received your inquiry regarding <strong><t t-out=\"object.name or ''\"/></strong>.</p>\n"
"                <p>One of our representatives will contact you shortly.</p>\n"
"                <p>Best regards,</p>\n"
"                <p><t t-out=\"object.company_id.name\"/></p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>Hola,</p>\n"
"                <p>¡Gracias por su interés! Hemos recibido su consulta sobre <strong><t t-out=\"object.name or ''\"/></strong>.</p>\n"
"                <p>Uno de nuestros representantes se pondrá en contacto con usted en breve.</p>\n"
"                <p>Atentamente,</p>\n"
"                <p><t t-out=\"object.company_id.name\"/></p>\n"
"            </div>\n"
"        "

#. module: crm_automation_engine
#: model:mail.template,body_html:crm_automation_engine.email_template_quote_confirmed_internal
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>Hi <t t-out=\"object.user_id.name\"/>,</p>\n"
"                <p>Great news! The quotation <strong><t t-out=\"object.name\"/></strong> has been confirmed by the customer.</p>\n"
"                <p>Amount: <t t-out=\"object.amount_total\"/></p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>Hola <t t-out=\"object.user_id.name\"/>,</p>\n"
"                <p>¡Buenas noticias! El presupuesto <strong><t t-out=\"object.name\"/></strong> ha sido confirmado por el cliente.</p>\n"
"                <p>Importe: <t t-out=\"object.amount_total\"/></p>\n"
"            </div>\n"
"        "

#. module: crm_automation_engine
#: model:mail.template,body_html:crm_automation_engine.email_template_client_welcome
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>Welcome <t t-out=\"object.name\"/>,</p>\n"
"                <p>We are thrilled to have you as a client at <strong><t t-out=\"object.company_id.name\"/></strong>.</p>\n"
"                <p>Feel free to reach out if you have any questions.</p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>Bienvenido/a <t t-out=\"object.name\"/>,</p>\n"
"                <p>Estamos encantados de tenerle como cliente en <strong><t t-out=\"object.company_id.name\"/></strong>.</p>\n"
"                <p>No dude en contactarnos si tiene alguna pregunta.</p>\n"
"            </div>\n"
"        "

