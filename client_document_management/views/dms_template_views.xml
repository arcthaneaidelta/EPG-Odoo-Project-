<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sign_oca_template_form_inherit" model="ir.ui.view">
        <field name="name">sign.oca.template.form.inherit</field>
        <field name="model">sign.oca.template</field>
        <field name="inherit_id" ref="sign_oca.sign_oca_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='model_id']" position="after">
                <field name="template_type"/>
            </xpath>
        </field>
    </record>
</odoo>
