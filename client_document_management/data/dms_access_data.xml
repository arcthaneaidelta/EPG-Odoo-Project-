<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Contract Managers mapping -->
        <record id="dms_access_contract_manager" model="dms.access.group">
            <field name="name">Contracts Access</field>
            <field name="perm_create" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="group_ids" eval="[(4, ref('client_document_management.group_dms_contract_manager'))]"/>
        </record>

        <!-- Invoice Users mapping -->
        <record id="dms_access_invoice_user" model="dms.access.group">
            <field name="name">Invoices Access</field>
            <field name="perm_create" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="group_ids" eval="[(4, ref('client_document_management.group_dms_invoice_user'))]"/>
        </record>

        <!-- Internal Users mapping -->
        <record id="dms_access_internal_user" model="dms.access.group">
            <field name="name">Internal Documents Access</field>
            <field name="perm_create" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="group_ids" eval="[(4, ref('client_document_management.group_dms_internal_user'))]"/>
        </record>
    </data>
</odoo>
