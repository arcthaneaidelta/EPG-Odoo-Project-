<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="crm_dashboard.CrmDashboardTemplate" owl="1">
        <div class="o_content crm_dashboard_root">
            <div class="crm_dash_shell">
                <aside class="crm_dash_sidebar">
                    <div class="crm_dash_brand">
                        <span class="crm_dash_brand_logo">E</span>
                        <div class="crm_dash_brand_text">
                            <span class="crm_dash_brand_name">
                                <t t-esc="state.data.companyName || 'Eficiencia Y'"/>
                            </span>
                            <span class="crm_dash_brand_sub">Productividad Global</span>
                        </div>
                    </div>

                    <ul class="crm_dash_menu">
                        <li class="active"><i class="fa fa-th-large"/> Dashboard</li>
<!--                        <li><i class="fa fa-line-chart"/> Sales</li>-->
<!--                        <li><i class="fa fa-users"/> Clients</li>-->
<!--                        <li><i class="fa fa-file-text-o"/> Accounting</li>-->
<!--                        <li><i class="fa fa-cube"/> Documents</li>-->
<!--                        <li><i class="fa fa-briefcase"/> Training</li>-->
<!--                        <li><i class="fa fa-android"/> AI Assistant</li>-->
                        <li><i class="fa fa-cog"/> Settings</li>
                    </ul>

                    <button class="crm_dash_logout" type="button">
                        <i class="fa fa-sign-out"/> Logout
                    </button>
                </aside>

                <section class="crm_dash_main">
                    <h1 class="crm_dash_page_title">Dashboard</h1>
                    <header class="crm_dash_topbar">
                        <label class="crm_dash_search">
                            <i class="fa fa-search"/>
                            <input
                                type="text"
                                placeholder="Search"
                                t-att-value="state.search"
                                t-on-input="onSearchInput"
                                t-on-keydown="onSearchKeydown"
                            />
                        </label>

                        <div class="crm_dash_user_meta">
                            <button type="button" class="crm_dash_icon_btn crm_dash_bell">
                                <i class="fa fa-bell"/>
                            </button>
                            <span class="crm_dash_avatar">
                                <t t-esc="(state.data.userName || 'U').charAt(0)"/>
                            </span>
                            <div class="crm_dash_user_text">
                                <strong t-esc="state.data.userName || 'User'"/>
                                <small t-esc="state.data.userEmail || 'info@example.com'"/>
                            </div>
                        </div>
                    </header>

                    <t t-if="state.loading">
                        <div class="crm_dash_loading">Loading CRM data...</div>
                    </t>

                    <div class="crm_dash_metrics_grid">
                        <t t-foreach="state.data.kpis" t-as="kpi" t-key="kpi.id">
                            <article
                                t-att-class="'crm_dash_metric_card crm_dash_clickable'"
                                t-on-click="() => this.onKpiClick(kpi)"
                            >
                                <div class="crm_dash_metric_text">
                                    <p t-esc="kpi.label"/>
                                    <h3 t-esc="kpi.formattedValue"/>
                                    <small
                                        t-if="kpi.trendLabel"
                                        t-att-class="'crm_dash_metric_trend ' + kpi.trendClass"
                                        t-esc="kpi.trendLabel"
                                    />
                                </div>
                                <svg viewBox="0 0 140 56" class="crm_dash_metric_chart" aria-hidden="true">
                                    <path
                                        class="crm_dash_metric_area"
                                        t-att-d="kpi.sparkAreaPath"
                                        t-att-style="'fill:' + kpi.sparkAreaColor + ';'"
                                    />
                                    <path
                                        class="crm_dash_metric_curve"
                                        t-att-d="kpi.sparkLinePath"
                                        t-att-style="'stroke:' + kpi.sparkLineColor + ';'"
                                    />
                                </svg>
                            </article>
                        </t>
                    </div>

                    <div class="crm_dash_chart_grid">
                        <article class="crm_dash_chart_panel crm_dash_sales_panel">
                            <div class="crm_dash_panel_head">
                                <span>Sales</span>
                                <div class="crm_dash_sales_actions">
                                    <label class="crm_dash_period_btn crm_dash_period_picker" t-on-click="onPeriodPickerClick">
                                        <span class="crm_dash_period_value">
                                            <t t-esc="state.data.salesChart.periodLabel || 'Select Month'"/>
                                        </span>
                                        <i class="fa fa-calendar-o"/>
                                        <input
                                            type="month"
                                            class="crm_dash_period_input_overlay"
                                            t-ref="periodInput"
                                            t-att-value="state.periodMonth"
                                            t-on-change="onPeriodChange"
                                        />
                                    </label>
                                    <button type="button" class="crm_dash_more_btn">
                                        <i class="fa fa-ellipsis-v"/>
                                    </button>
                                </div>
                            </div>

                            <div class="crm_dash_sales_chart_wrap">
                                <div class="crm_dash_sales_y_axis">
                                    <t t-foreach="state.data.salesChart.yTicks" t-as="tick" t-key="tick.y">
                                        <span t-att-style="'top:' + tick.topPercent + '%;'" t-esc="tick.label"/>
                                    </t>
                                </div>

                                <svg viewBox="0 0 610 260" class="crm_dash_line_chart" aria-hidden="true">
                                    <t t-foreach="state.data.salesChart.yTicks" t-as="tickLine" t-key="tickLine.y">
                                        <line x1="12" t-att-y1="tickLine.y" x2="590" t-att-y2="tickLine.y"/>
                                    </t>
                                    <path class="crm_dash_main_curve" t-att-d="state.data.salesChart.path"/>
                                    <line class="crm_dash_marker" t-att-x1="state.data.salesChart.markerX" y1="24" t-att-x2="state.data.salesChart.markerX" y2="232"/>
                                    <circle t-att-cx="state.data.salesChart.markerX" t-att-cy="state.data.salesChart.markerY" r="6"/>

                                    <rect
                                        t-att-x="state.data.salesChart.markerX - 28"
                                        y="2"
                                        width="56"
                                        height="42"
                                        rx="8"
                                        class="crm_dash_marker_label_bg"
                                    />
                                    <text
                                        t-att-x="state.data.salesChart.markerX"
                                        y="14"
                                        text-anchor="middle"
                                        class="crm_dash_marker_label_caption"
                                    >Sales</text>
                                    <text
                                        t-att-x="state.data.salesChart.markerX"
                                        y="29"
                                        text-anchor="middle"
                                        class="crm_dash_marker_label_value"
                                        t-esc="state.data.salesChart.markerLabel"
                                    />
                                </svg>

                                <div class="crm_dash_axis">
                                    <t t-foreach="state.data.salesChart.xTicks" t-as="xTick" t-key="xTick.leftPercent">
                                        <span t-att-style="'left:' + xTick.leftPercent + '%;'" t-esc="xTick.label"/>
                                    </t>
                                </div>
                            </div>
                        </article>

                        <article class="crm_dash_chart_panel crm_dash_donut_panel">
                            <div class="crm_dash_panel_head">
                                <span>Leads vs Won</span>
                            </div>

                            <div class="crm_dash_donut_wrap">
                                <div
                                    class="crm_dash_donut"
                                    t-att-style="state.data.donutStyle"
                                    t-on-mousemove="onDonutMouseMove"
                                    t-on-mouseleave="onDonutItemLeave"
                                >
                                    <div class="crm_dash_donut_center">
                                        <strong t-if="state.donutHoverValue" t-esc="state.donutHoverValue"/>
                                    </div>
                                </div>

                                <t t-if="state.data.wonDistribution.length">
                                    <ul class="crm_dash_legend">
                                        <t t-foreach="state.data.wonDistribution" t-as="item" t-key="item.name + '_' + item.value">
                                            <li
                                                t-on-mouseenter="() => this.onDonutItemEnter(item)"
                                                t-on-mouseleave="onDonutItemLeave"
                                            >
                                                <span class="dot" t-att-style="'background:' + item.color + ';'"/>
                                                <div class="crm_dash_legend_text">
                                                    <span t-esc="item.name"/>
                                                    <strong t-esc="item.formattedValue"/>
                                                </div>
                                            </li>
                                        </t>
                                    </ul>
                                </t>
                                <t t-else="">
                                    <div class="crm_dash_empty_note">No lead comparison data yet.</div>
                                </t>
                            </div>
                        </article>
                    </div>

<!--                    <article class="crm_dash_table_panel">-->
<!--                        <div class="crm_dash_table_head">CRM Data Table</div>-->
<!--                        <t t-if="state.data.tableRows.length">-->
<!--                            <div class="crm_dash_table_wrap">-->
<!--                                <table class="crm_dash_table">-->
<!--                                    <thead>-->
<!--                                        <tr>-->
<!--                                            <th>Lead / Opportunity</th>-->
<!--                                            <th>Type</th>-->
<!--                                            <th>Stage</th>-->
<!--                                            <th class="text-end">Expected Revenue</th>-->
<!--                                            <th class="text-end">Probability</th>-->
<!--                                            <th>Created</th>-->
<!--                                        </tr>-->
<!--                                    </thead>-->
<!--                                    <tbody>-->
<!--                                        <t t-foreach="state.data.tableRows" t-as="row" t-key="row.id">-->
<!--                                            <tr>-->
<!--                                                <td t-esc="row.name"/>-->
<!--                                                <td t-esc="row.type"/>-->
<!--                                                <td t-esc="row.stage"/>-->
<!--                                                <td class="text-end" t-esc="row.revenueLabel"/>-->
<!--                                                <td class="text-end" t-esc="row.probabilityLabel"/>-->
<!--                                                <td t-esc="row.createDateLabel"/>-->
<!--                                            </tr>-->
<!--                                        </t>-->
<!--                                    </tbody>-->
<!--                                </table>-->
<!--                            </div>-->
<!--                        </t>-->
<!--                        <t t-else="">-->
<!--                            <div class="crm_dash_empty_note">No CRM records found.</div>-->
<!--                        </t>-->
<!--                    </article>-->
                </section>
            </div>
        </div>
    </t>
</templates>
