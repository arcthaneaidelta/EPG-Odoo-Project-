<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="payment_acquirer_redsys" model="payment.acquirer">
        <field name="name">Redsys</field>
        <field name="module_id" ref="base.module_payment_redsys_v1"/>
        <field name="description" type="html">
            <p>
                Pasarela de pagos para aceptar pagos online.
            </p>
            <ul class="list-inline">
                <li class="list-inline-item"><i class="fa fa-check"/>Pago Online</li>
                <li class="list-inline-item"><i class="fa fa-check"/>Seguimiento de pago</li>
            </ul>
        </field>
        <field name="provider">redsys</field>
        <field name="state">test</field>
        <field name="pre_msg"><![CDATA[
        <p></p>]]></field>

        <field name="redsys_merchant_name">Nombre del Comercio</field>
        <field name="redsys_merchant_code"></field>
        <field name="redsys_merchant_description"></field>
        <field name="redsys_secret_key"></field>
        <field name="image_128" type="base64" file="redsys_integration/static/src/img/redsys.png"/>
        <field name="redirect_form_view_id"  ref="redirect_form" />
        <field name="support_authorization">False</field>
        <field name="support_fees_computation">False</field>
        <field name="support_refund"></field>
        <field name="support_tokenization">False</field>
    </record>
    
    <record id="payment_acquirer_redsys_bizum" model="payment.acquirer">
        <field name="name">Bizum</field>
        <field name="module_id" ref="base.module_payment_redsys_v1"/>
        <field name="description" type="html">
            <p>
                Pasarela de pagos para aceptar pagos online a través de Bizum.
            </p>
            <ul class="list-inline">
                <li class="list-inline-item"><i class="fa fa-check"/>Pago Online</li>
                <li class="list-inline-item"><i class="fa fa-check"/>Seguimiento de pago</li>
            </ul>
        </field>
        <field name="provider">redsys</field>
        <field name="state">test</field>
        <field name="pre_msg"><![CDATA[
        <p></p>]]></field>

        <field name="redsys_merchant_name">Nombre del Comercio</field>
        <field name="redsys_merchant_code"></field>
        <field name="redsys_merchant_description"></field>
        <field name="redsys_secret_key"></field>
        <field name="image_128" type="base64" file="redsys_integration/static/src/img/redsys.png"/>
        <field name="redirect_form_view_id"  ref="redirect_form" />
        <field name="support_authorization">False</field>
        <field name="redsys_pay_method">z</field>
        <field name="support_fees_computation">False</field>
        <field name="support_refund"></field>
        <field name="support_tokenization">False</field>
    </record>

    <record id="payment_method_redsys" model="account.payment.method">
        <field name="name">Redsys</field>
        <field name="code">redsys</field>
        <field name="payment_type">inbound</field>
    </record>

</odoo>
